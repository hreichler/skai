# VoiceRun local secrets (if any)
apps/*/.voicerun/secrets*

# Veris AI Reliability Harness (Story 2.6) — generated artefacts.
# .veris/config.yaml is intentionally committed (env id is not a secret).
apps/agent/veris-report-*.html
apps/agent/.veris/*.log

# VoiceRun runtime debug dumps (per-session, generated by vr debug).
apps/agent/debugger-session-*.json
apps/agent/debugger-session-*.jsonl
apps/agent/debugger-stderr-*.log
apps/agent/session-*-events.json
apps/agent/debug-*.err
apps/agent/debug-*.log
apps/agent/push-*.log
apps/agent/deploy-*.log
apps/agent/.voicerun/agent.lock

